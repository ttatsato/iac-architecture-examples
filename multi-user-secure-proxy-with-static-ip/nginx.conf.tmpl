worker_processes auto;
events {
    worker_connections 1024;
}

http {
    resolver 8.8.8.8 1.1.1.1 valid=60s;
    proxy_http_version 1.1;
    proxy_ssl_server_name on;
    proxy_ssl_protocols TLSv1.2 TLSv1.3;

    # IAP forwards verified user identity in this header.
    # See: https://cloud.google.com/iap/docs/identity-howto
    map $http_x_goog_authenticated_user_email $iap_user {
        default "";
        "~^accounts.google.com:(?<u>.+)$" $u;
    }

    log_format main '$remote_addr "$request" $status iap_user="$iap_user" '
                    'ua="$http_user_agent" rt=$request_time';
    access_log /var/log/nginx/access.log main;

    server {
        listen 8080;
        server_name _;

        # Health check endpoint for the GCP load balancer
        location = /healthz {
            access_log off;
            return 200 "ok\n";
        }

        location / {
            proxy_pass https://${vendor_host};
            proxy_set_header Host ${vendor_host};
            proxy_set_header X-Forwarded-For $remote_addr;
            proxy_set_header X-Forwarded-Proto https;
            proxy_set_header X-Forwarded-Host ${gateway_host};

            # Rewrite redirects from vendor host to our gateway host
            proxy_redirect https://${vendor_host}/ https://${gateway_host}/;
            proxy_redirect http://${vendor_host}/  https://${gateway_host}/;

            # Rewrite cookie domain so sessions stick on the gateway host
            proxy_cookie_domain ${vendor_host} ${gateway_host};

            # Don't buffer streaming responses
            proxy_buffering off;
            proxy_request_buffering off;

            # Sane timeouts
            proxy_connect_timeout 30s;
            proxy_send_timeout    60s;
            proxy_read_timeout    60s;
        }
    }
}
